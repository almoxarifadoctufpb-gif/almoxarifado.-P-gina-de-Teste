  function gerarImagemSvg(nomeItem) {
    let iconType = "inventory";
    const lower = nomeItem.toLowerCase();
    if (lower.includes("caneta")) iconType = "create";
    else if (lower.includes("papel")) iconType = "description";
    else if (lower.includes("pilha")) iconType = "battery_charging_full";
    else if (lower.includes("desinfetante")) iconType = "clean_hands";
    else iconType = "inventory";
    const svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="48" height="48" fill="#2C5F7A"><path d="M0 0h24v24H0z" fill="none"/><path d="M4 6h16v2H4V6zm2-4h12v2H6V2zm16 8H2v12h20V10zm-2 10H4v-8h16v8z"/></svg>`;
    return `data:image/svg+xml,${encodeURIComponent(svg)}`;
  }

  function renderCatalogo() {
    const grouped = {};
    materiaisDB.forEach(mat => { if (!grouped[mat.categoria]) grouped[mat.categoria] = { nome: mat.categoriaNome, itens: [] }; grouped[mat.categoria].itens.push(mat); });
    const container = document.getElementById('catalogoContainer');
    container.innerHTML = '';
    for (let [cod, grupo] of Object.entries(grouped)) {
      const cardCat = document.createElement('div'); cardCat.className = 'categoria-card';
      cardCat.innerHTML = `<div class="cat-header"><h2>${grupo.nome}</h2><span class="codigo">Código ${cod}</span></div><div class="materiais-grid" id="grid-${cod}"></div>`;
      container.appendChild(cardCat);
      const gridDiv = cardCat.querySelector(`.materiais-grid`);
      grupo.itens.forEach(item => {
        const imgSrc = gerarImagemSvg(item.nome);
        const card = document.createElement('div'); card.className = 'material-card';
        card.innerHTML = `<div class="img-material"><img src="${imgSrc}" alt="${item.nome}"></div><div class="material-nome">${item.nome}</div><button class="btn-add-material" data-nome="${item.nome.replace(/"/g, '&quot;')}"><i class="material-icons">add_shopping_cart</i> Adicionar</button>`;
        gridDiv.appendChild(card);
      });
    }
    document.querySelectorAll('.btn-add-material').forEach(btn => btn.addEventListener('click', (e) => { e.stopPropagation(); adicionarAoCarrinho(btn.getAttribute('data-nome')); }));
  }

  let carrinho = [];
  function salvarCarrinho() { localStorage.setItem('carrinhoAlmox', JSON.stringify(carrinho)); renderizarCarrinho(); }
  function adicionarAoCarrinho(nome) {
    const existente = carrinho.find(i => i.nome === nome);
    if (existente) existente.quantidade++;
    else carrinho.push({ nome, quantidade: 1, imagem: gerarImagemSvg(nome) });
    salvarCarrinho();
    Swal.fire({ icon: 'success', title: 'Adicionado!', text: `${nome} adicionado.`, toast: true, position: 'top-end', showConfirmButton: false, timer: 1200 });
  }
  function removerItem(idx) { carrinho.splice(idx,1); salvarCarrinho(); }
  function alterarQtd(idx, delta) {
    let nova = carrinho[idx].quantidade + delta;
    if (nova <= 0) removerItem(idx);
    else { carrinho[idx].quantidade = nova; salvarCarrinho(); }
  }
  function renderizarCarrinho() {
    const container = document.getElementById('cartItemsList');
    const totalSpan = document.getElementById('cartTotalQtd');
    if (!carrinho.length) { container.innerHTML = '<div class="vazio-msg">Nenhum material adicionado.</div>'; totalSpan.innerText = '0'; return; }
    let totalItens = 0;
    let html = '';
    carrinho.forEach((item, idx) => { totalItens += item.quantidade;
      html += `<div class="cart-item"><div class="cart-item-img"><img src="${item.imagem}"></div><div class="cart-item-info"><div class="cart-item-name">${item.nome}</div><div class="cart-item-qtd"><button class="qtd-down" data-index="${idx}">-</button><span>${item.quantidade}</span><button class="qtd-up" data-index="${idx}">+</button></div></div><button class="remove-item" data-index="${idx}"><i class="material-icons">close</i></button></div>`;
    });
    container.innerHTML = html;
    totalSpan.innerText = totalItens;
    document.querySelectorAll('.qtd-down').forEach(btn => btn.addEventListener('click', (e) => alterarQtd(parseInt(btn.dataset.index), -1)));
    document.querySelectorAll('.qtd-up').forEach(btn => btn.addEventListener('click', (e) => alterarQtd(parseInt(btn.dataset.index), 1)));
    document.querySelectorAll('.remove-item').forEach(btn => btn.addEventListener('click', (e) => removerItem(parseInt(btn.dataset.index))));
  }
  function carregarCarrinho() { const saved = localStorage.getItem('carrinhoAlmox'); if (saved) { try { carrinho = JSON.parse(saved); carrinho.forEach(i => i.imagem = gerarImagemSvg(i.nome)); } catch(e){} } renderizarCarrinho(); }

  // Geração do texto da mensagem para a página de atendimento
  function gerarTextoMensagem(dadosSolicitante, setor, itensCarrinho) {
    let itensTexto = itensCarrinho.map(i => `- ${i.nome}: ${i.quantidade} unidade(s)`).join('\n');
    return `**SOLICITAÇÃO DE MATERIAIS - ALMOXARIFADO CT UFPB**\n\n` +
           `**Setor solicitante:** ${setor}\n` +
           `**Solicitante:** ${dadosSolicitante.nome}\n` +
           `**CPF:** ${dadosSolicitante.cpf}\n` +
           `**E-mail:** ${dadosSolicitante.email}\n` +
           `**Contato:** ${dadosSolicitante.contato}\n` +
           `**Perfil:** ${dadosSolicitante.perfil}\n` +
           `**Lotação:** ${dadosSolicitante.lotacao}\n` +
           `**Assunto:** ${dadosSolicitante.assunto}\n\n` +
           `**Itens solicitados:**\n${itensTexto}\n\n` +
           `Data da solicitação: ${new Date().toLocaleString()}`;
  }

  // Gerar PDF
  async function gerarPDF(dados, setor, itens) {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF();
    doc.setFont("helvetica");
    doc.setFontSize(16);
    doc.text("REQUISIÇÃO DE MATERIAIS - ALMOXARIFADO CT UFPB", 15, 20);
    doc.setFontSize(12);
    doc.text(`Setor: ${setor}`, 15, 35);
    doc.text(`Solicitante: ${dados.nome}`, 15, 45);
    doc.text(`CPF: ${dados.cpf}`, 15, 55);
    doc.text(`E-mail: ${dados.email}`, 15, 65);
    doc.text(`Contato: ${dados.contato}`, 15, 75);
    doc.text(`Perfil: ${dados.perfil}`, 15, 85);
    doc.text(`Lotação: ${dados.lotacao}`, 15, 95);
    doc.text(`Assunto: ${dados.assunto}`, 15, 105);
    doc.text("Itens solicitados:", 15, 120);
    let y = 130;
    itens.forEach(item => {
      doc.text(`• ${item.nome} - ${item.quantidade} unidade(s)`, 20, y);
      y += 8;
      if (y > 270) { doc.addPage(); y = 20; }
    });
    doc.text(`Gerado em: ${new Date().toLocaleString()}`, 15, y+10);
    doc.save(`solicitacao_almox_${dados.cpf}.pdf`);
  }

  // Botão WhatsApp
  document.getElementById('btnWhatsapp').addEventListener('click', () => {
    const numero = "558332167082";
    const msg = "Olá, gostaria de solicitar materiais para o Almoxarifado do CT. Já possuo meu carrinho no sistema interno.";
    window.open(`https://wa.me/${numero}?text=${encodeURIComponent(msg)}`, '_blank');
  });

  // Fluxo de solicitação (modal)
  const modal = document.getElementById('solicitanteModal');
  const btnSolicitar = document.getElementById('btnSolicitar');
  btnSolicitar.addEventListener('click', () => {
    const sector = document.getElementById('sectorSelect').value;
    if (!sector) { Swal.fire('Atenção', 'Selecione o setor solicitante.', 'warning'); return; }
    if (carrinho.length === 0) { Swal.fire('Carrinho vazio', 'Adicione pelo menos um material.', 'error'); return; }
    modal.style.display = 'flex';
  });

  document.getElementById('confirmarSolicitacao').addEventListener('click', async () => {
    const cpf = document.getElementById('cpf').value.trim();
    const nome = document.getElementById('nomeSolicitante').value.trim();
    const email = document.getElementById('email').value.trim();
    const contato = document.getElementById('contato').value.trim();
    const perfil = document.getElementById('perfil').value;
    const lotacao = document.getElementById('lotacao').value.trim();
    const assunto = document.getElementById('assunto').value.trim();
    if (!cpf || cpf.length !== 11 || !/^\d+$/.test(cpf)) { Swal.fire('Erro', 'CPF inválido (11 dígitos numéricos).', 'error'); return; }
    if (!nome || !email || !contato || !lotacao) { Swal.fire('Erro', 'Preencha todos os campos obrigatórios.', 'error'); return; }
    const sector = document.getElementById('sectorSelect').value;
    const dadosSolicitante = { cpf, nome, email, contato, perfil, lotacao, assunto };
    const itensCarrinho = [...carrinho];
    const textoMensagem = gerarTextoMensagem(dadosSolicitante, sector, itensCarrinho);

    // Exibir o texto e abrir página de atendimento
    await Swal.fire({
      title: 'Pedido gerado com sucesso!',
      html: `<div style="text-align:left">Agora você será redirecionado para a página de atendimento do CT.<br>
      <strong>Copie o texto abaixo e cole no campo "Mensagem" do formulário:</strong><br>
      <div class="copy-area" id="textoParaCopiar" style="background:#f0f0f0;padding:12px;border-radius:12px;max-height:200px;overflow:auto;">${textoMensagem.replace(/\n/g,'<br>')}</div>
      <button id="btnCopiarTexto" class="btn-modal" style="margin-top:10px; background:#0B2B40;">📋 Copiar mensagem</button></div>`,
      icon: 'success',
      showConfirmButton: true,
      confirmButtonText: 'Abrir página de atendimento',
      showCancelButton: true,
      cancelButtonText: 'Fechar'
    }).then(async (result) => {
      if (result.isConfirmed) {
        window.open('https://atendimento.ct.ufpb.br/index.php?category=4&a=add', '_blank');
      }
    });
    // Adicionar evento de cópia manual após o modal ser exibido (com delay)
    setTimeout(() => {
      const btnCopy = document.getElementById('btnCopiarTexto');
      if (btnCopy) btnCopy.onclick = () => {
        navigator.clipboard.writeText(textoMensagem);
        Swal.fire('Copiado!', 'Texto da solicitação copiado para área de transferência.', 'success');
      };
    }, 100);
    // Gerar PDF
    await gerarPDF(dadosSolicitante, sector, itensCarrinho);
    Swal.fire('PDF gerado', 'O arquivo PDF com a solicitação foi baixado automaticamente.', 'info');
    // Limpar carrinho e fechar modal
    carrinho = [];
    salvarCarrinho();
    modal.style.display = 'none';
    document.getElementById('cpf').value = '';
    document.getElementById('nomeSolicitante').value = '';
    document.getElementById('email').value = '';
    document.getElementById('contato').value = '';
    document.getElementById('lotacao').value = '';
    document.getElementById('assunto').value = 'Solicitação de materiais ao Almoxarifado CT';
  });

  window.onclick = (e) => { if (e.target === modal) modal.style.display = 'none'; };
  document.getElementById('btnLimparCarrinho').addEventListener('click', () => {
    if(carrinho.length === 0) return;
    Swal.fire({ title: 'Limpar carrinho?', text: 'Todos os itens serão removidos', icon: 'question', showCancelButton: true, confirmButtonColor: '#d33', confirmButtonText: 'Sim' }).then(res => { if(res.isConfirmed) { carrinho = []; salvarCarrinho(); Swal.fire('Carrinho esvaziado','','success'); } });
  });

  renderCatalogo();
  carregarCarrinho();
</script>
